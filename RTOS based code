/* ================= RTOS-STYLE TASK SCHEDULER ================= */
// Task states for fine-grained control
enum TaskState {
  TASK_READY = 0,
  TASK_RUNNING = 1,
  TASK_WAITING = 2,
  TASK_COMPLETE = 3
};

// Generic task structure
struct Task {
  uint32_t nextRunTime;   // Next execution time in micros (for FSM) or millis (for periodic)
  uint32_t interval;      // Execution interval
  uint8_t state;          // Internal state machine
  boolean enabled;        // Task enabled flag
  void (*handler)(void);  // Task handler function pointer
};

// Task list - one for each sensor/display
